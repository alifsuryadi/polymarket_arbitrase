# Salin file ini menjadi .env dan isi nilainya
# cp .env.example .env

# ─── Wallet (hanya untuk live trading) ───────────────────
# Private key wallet Polygon kamu (JANGAN share ke siapapun!)
POLY_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Alamat wallet publik kamu
POLY_WALLET_ADDRESS=0xYOUR_WALLET_ADDRESS_HERE

# ─── Konfigurasi Bot (opsional, ada default) ──────────────
# Minimum profit sebelum dianggap peluang (USD)
PROFIT_THRESHOLD=0.01

# Ukuran taruhan per kontrak
BET_SIZE_SHARES=1.0

# Estimasi gas fee per order di Polygon (USD)
GAS_FEE_PER_TX=0.002

# Interval polling dalam detik
POLL_INTERVAL_SECONDS=10
